---
import { SKILL_GROUPS } from '../data/resume'
---

<section id="skills" aria-labelledby="skills-heading" class="section">
  <div class="container">
    <p class="section-label" aria-hidden="true">// Stack</p>
    <h2 id="skills-heading" class="section-title">Skills</h2>

    <div class="skill-groups">
      {
        SKILL_GROUPS.map((group) => (
          <div class="skill-group">
            <h3 class="group-label">{group.label}</h3>
            <ul class="skill-list" role="list">
              {group.skills.map((skill) => (
                <li class="skill-tag">{skill}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .container {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }

  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .group-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .skill-tag {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-2);
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.375rem 0.875rem;
    border-radius: 6px;
    transition: border-color 0.15s, color 0.15s;
  }
  .skill-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
