---
interface Props {
  title: string;
  company: string;
  link?: string;
  date: string;
}

const { title, company, date } = Astro.props;
---

<li class="edu-item card">
  <div class="edu-left">
    <h3 class="edu-title">{title}</h3>
    <p class="edu-company">{company}</p>
  </div>
  <time class="edu-date">{date}</time>
</li>

<style lang="scss">
  .edu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 22px;
    flex-wrap: wrap;
    transition: border-color .2s, transform .2s;
    &:hover { transform: translateX(4px); }
  }

  .edu-title {
    font-size: .95rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
  }

  .edu-company {
    font-size: .82rem;
    color: var(--accent);
    margin-top: 3px;
  }

  .edu-date {
    font-family: var(--font-mono);
    font-size: .72rem;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
