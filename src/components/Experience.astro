---
import { EXPERIENCE } from '../data/resume'
---

<section id="experience" aria-labelledby="experience-heading" class="section">
  <div class="container">
    <p class="section-label" aria-hidden="true">// Trayectoria</p>
    <h2 id="experience-heading" class="section-title">Experiencia</h2>

    <ol class="exp-list" role="list">
      {
        EXPERIENCE.map((job) => (
          <li class="exp-item">
            <div class="exp-period">
              <time datetime={job.dateStart}>{job.period.split('–')[0].trim()}</time>
              {' – '}
              <time datetime={job.dateEnd}>{job.period.split('–')[1].trim()}</time>
            </div>
            <article class="exp-content" aria-label={`${job.role} en ${job.company}`}>
              <h3 class="exp-role">{job.role}</h3>
              <p class="exp-company">{job.company}</p>
              <p class="exp-desc">{job.description}</p>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .section {
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  .section-label::before {
    content: '';
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .container {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }

  .exp-list {
    display: flex;
    flex-direction: column;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 13rem 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .exp-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    padding-top: 0.25rem;
    line-height: 1.4;
  }

  .exp-role {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .exp-company {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .exp-desc {
    font-size: 0.875rem;
    color: var(--ink-2);
    line-height: 1.65;
  }

  @media (max-width: 600px) {
    .exp-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
