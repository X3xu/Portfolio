---
import ExperienceItem from "./ExperienceItem.astro";

const EXPERIENCE = [
  {
    date: "Jun 2025 — May 2026",
    title: "Front-End Specialist Developer",
    company: "Civitatis",
    location: "Madrid, España",
    description: "Lideré la migración crítica de plataformas core desde arquitecturas legacy hacia SPA modernas con React 19 y Next.js. Diseñé e implementé el Sistema de Diseño corporativo integrando Storybook. Optimicé los flujos de ingeniería incorporando IA y protocolos MCP, incrementando significativamente la productividad del equipo.",
    stack: ["React 19", "Next.js", "TypeScript", "Storybook", "Optimizely", "Vitest", "AI/MCPs"],
  },
  {
    date: "Sep 2022 — Jun 2025",
    title: "Front-End Developer",
    company: "Thinkabit",
    location: "Madrid, España",
    description: "Dirigí la evolución técnica del portal corporativo con arquitectura de componentes modulares en Vue. Mejoré drásticamente los Core Web Vitals y el diseño accesible. Implementé pipelines CI/CD completos con GitLab, Jenkins y Docker. Colaboré en Scrum integrando APIs REST y arquitecturas CMS en WordPress.",
    stack: ["Vue", "JavaScript ES6+", "HTML5/SASS", "Webpack", "Docker", "Jenkins", "SonarQube"],
  },
  {
    date: "Dic 2021 — Sep 2022",
    title: "FullStack Developer",
    company: "Minsait (Indra)",
    location: "Madrid, España",
    description: "Migración tecnológica estructural de módulos XML a tecnologías dinámicas JSP en entornos de banca privada. Gestión de interlocución técnica directa con el cliente, traduciendo requerimientos de negocio en soluciones funcionales sobre entornos Linux.",
    stack: ["Java", "JSP", "XML", "Linux"],
  },
  {
    date: "Mar 2021 — Dic 2021",
    title: "FullStack Developer",
    company: "NTT Data",
    location: "Madrid, España",
    description: "Desarrollo de aplicaciones corporativas con Spring Boot en backend y Angular 11 en frontend. Implementación de suites de pruebas unitarias con JUnit y diseño de consultas SQL complejas para extracción y manipulación eficiente de datos.",
    stack: ["Spring Boot", "Angular 11", "Java", "SQL", "JUnit"],
  },
];
---

<section id="experience" class="sr">
  <p class="section-label">// trayectoria</p>
  <h2 class="section-title">Experiencia profesional</h2>

  <ol class="timeline">
    {EXPERIENCE.map((item, i) => (
      <ExperienceItem {...item} index={i + 1} />
    ))}
  </ol>
</section>

<style lang="scss">
  .timeline {
    margin-top: 44px;
    display: flex;
    flex-direction: column;
    list-style: none;
    position: relative;

    &::before {
      content: '';
      position: absolute;
      left: 15px;
      top: 8px;
      bottom: 8px;
      width: 1px;
      background: linear-gradient(to bottom, var(--accent), rgba(79,70,229,.1), transparent);
    }
  }
</style>
