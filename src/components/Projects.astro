---
import { PROJECTS } from '../data/resume'
---

<section id="projects" aria-labelledby="projects-heading" class="section">
  <div class="container">
    <p class="section-label" aria-hidden="true">// Work</p>
    <h2 id="projects-heading" class="section-title">Proyectos</h2>

    <ul class="project-list" role="list">
      {
        PROJECTS.map((project, i) => (
          <li class="project-item">
            <article aria-labelledby={`project-title-${i}`}>
              <div class="project-main">
                <div class="project-text">
                  <span class="project-num" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <h3 id={`project-title-${i}`} class="project-name">
                    {project.title}
                  </h3>
                  <p class="project-desc">{project.description}</p>
                  <ul class="project-tags" role="list" aria-label="Tecnologías usadas">
                    {project.tags.map((tag) => (
                      <li class="project-tag">{tag}</li>
                    ))}
                  </ul>
                </div>
                <div class="project-image-wrap">
                  <img
                    src={project.image}
                    alt={`Captura de pantalla de ${project.title}`}
                    class="project-image"
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="225"
                  />
                </div>
              </div>
              <div class="project-links">
                <a
                  href={project.demo}
                  class="project-link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver demo de ${project.title} (abre en nueva pestaña)`}
                >
                  Demo&nbsp;↗
                </a>
                <a
                  href={project.repo}
                  class="project-link project-link--ghost"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Ver código de ${project.title} en GitHub (abre en nueva pestaña)`}
                >
                  GitHub&nbsp;↗
                </a>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section {
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin-bottom: 3rem;
  }

  .container {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }

  .project-list {
    display: flex;
    flex-direction: column;
    list-style: none;
  }

  .project-item {
    border-bottom: 1px solid var(--border);
    padding: 2rem 0;
  }
  .project-item:first-child {
    padding-top: 0;
  }
  .project-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .project-main {
    display: grid;
    grid-template-columns: 1fr 22rem;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 1.25rem;
  }

  .project-num {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--ink-2);
    line-height: 1.65;
    margin-bottom: 0.875rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
  }

  .project-tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--ink-2);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .project-image-wrap {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    aspect-ratio: 16 / 9;
    background: var(--bg-subtle);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .project-item:hover .project-image {
    transform: scale(1.03);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  .project-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-card);
    transition: border-color 0.15s, color 0.15s;
  }
  .project-link:hover {
    border-color: var(--ink);
  }

  .project-link--ghost {
    color: var(--muted);
  }
  .project-link--ghost:hover {
    color: var(--ink);
    border-color: var(--ink);
  }

  @media (max-width: 768px) {
    .project-main {
      grid-template-columns: 1fr;
    }
    .project-image-wrap {
      order: -1;
    }
  }
</style>
