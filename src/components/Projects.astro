---
import GitHub from "../icons/Github.astro";
import React from "../icons/React.astro";
import Tailwind from "../icons/Tailwind.astro";
import icoAstro from "../icons/icoAstro.astro";
import icoScript from "../icons/JavaScript.astro";
import HTML from "../icons/HTML.astro";
import CSS from "../icons/CSS.astro";
import NextJS from "../icons/NextJS.astro";
import TypeScript from "../icons/TypeScript.astro";
import Supabase from "../icons/Supabase.astro";
import FramerMotion from "../icons/FramerMotion.astro";
import Vite from "../icons/Vite.astro";

const TAGS = {
  NEXT:         { name: "Next.js",       icon: NextJS },
  REACT:        { name: "React 19",      icon: React },
  REACT18:      { name: "React 18",      icon: React },
  TAILWIND:     { name: "Tailwind CSS",  icon: Tailwind },
  ASTRO:        { name: "Astro",         icon: icoAstro },
  TS:           { name: "TypeScript",    icon: TypeScript },
  JS:           { name: "JavaScript",    icon: icoScript },
  HTML:         { name: "HTML",          icon: HTML },
  CSS:          { name: "CSS",           icon: CSS },
  SUPABASE:     { name: "Supabase",      icon: Supabase },
  FRAMER:       { name: "Framer Motion", icon: FramerMotion },
  VITE:         { name: "Vite",          icon: Vite },
};

const PROJECTS = [
  {
    num: "01",
    title: "UI Template",
    description:
      "Plantilla web responsive desarrollada como prueba técnica. Diseño moderno con interacciones dinámicas en HTML, CSS y JS vanilla.",
    link: "https://waveless-blond.vercel.app/",
    github: "https://github.com/X3xu/waveless.git",
    image: "waveless.webp",
    tags: [TAGS.JS, TAGS.HTML, TAGS.CSS],
  },
  {
    num: "02",
    title: "QuizzGame",
    description:
      "Juego de trivia construido con React y Vite. Selección de categorías, temporizador por pregunta, puntuación y pantalla de resultados.",
    link: "https://quizzzgame.vercel.app/",
    github: "https://github.com/X3xu/quizzGame",
    image: "QuizzGame.webp",
    tags: [TAGS.REACT18, TAGS.JS, TAGS.VITE],
  },
  {
    num: "03",
    title: "Star Wars Explorer",
    description:
      "SPA que consume la API pública de Star Wars para explorar personajes, naves y planetas con navegación fluida.",
    link: "https://star-wars-seven-iota.vercel.app/",
    github: "https://github.com/X3xu/star-wars",
    image: "SWAPI.webp",
    tags: [TAGS.JS],
  },
  {
    num: "04",
    title: "Portfolio — JJD",
    description:
      "Este mismo portfolio. Generado estáticamente con Astro, fondo canvas interactivo, cursor personalizado, scroll reveal, tilt 3D y sistema de temas claro/oscuro.",
    link: "https://jesusjimenezdillana.vercel.app/",
    github: "https://github.com/X3xu/Portfolio",
    image: "Portfolio.webp",
    tags: [TAGS.ASTRO, TAGS.TS, TAGS.TAILWIND],
  },
];
---

<section id="projects" class="sr">
  <p class="section-label">// proyectos</p>
  <h2 class="section-title">Lo que he construido</h2>

  <div class="projects-grid">
    {PROJECTS.map(({ num, title, description, tags, link, github, image }) => (
      <article class="project-item tilt card sr">
        <div class="tilt-sh"></div>

        <a class="project-image-link" href={link} target="_blank" rel="noopener" aria-label={`Ver demo de ${title}`}>
          <div class="project-img-wrap">
            <img
              src={image}
              alt={title}
              class="project-img"
              loading="lazy"
            />
            <div class="project-overlay">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
              <span>Ver demo</span>
            </div>
          </div>
        </a>

        <div class="project-body">
          <div class="project-top">
            <span class="project-num">{num}</span>
            <div class="project-actions">
              {github && (
                <a class="icon-btn" href={github} target="_blank" rel="noopener" aria-label="Código fuente">
                  <GitHub />
                </a>
              )}
              {link && (
                <a class="icon-btn icon-btn--accent" href={link} target="_blank" rel="noopener" aria-label="Ver demo">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
                </a>
              )}
            </div>
          </div>

          <h3 class="project-title">{title}</h3>
          <p class="project-desc">{description}</p>

          <ul class="project-tags">
            {tags.map(tag => (
              <li>
                <span class="tag">
                  <tag.icon class="tag-icon" />
                  {tag.name}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<style lang="scss">
  .projects-grid {
    margin-top: 44px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .project-item {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform .18s ease-out, border-color .2s;

    &:hover .project-img {
      transform: scale(1.05);
    }

    &:hover .project-overlay {
      opacity: 1;
    }
  }

  /* ── Image block ── */
  .project-image-link {
    display: block;
    text-decoration: none;
  }

  .project-img-wrap {
    position: relative;
    overflow: hidden;
    height: 190px;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform .5s var(--ease-out);
    display: block;
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(95, 20, 245, 0.82);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: #fff;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity .28s;

    svg { opacity: .9; }
  }

  /* ── Body ── */
  .project-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .project-num {
    font-family: var(--font-mono);
    font-size: .65rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: .1em;
  }

  .project-actions {
    display: flex;
    gap: 6px;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--muted);
    text-decoration: none;
    transition: color .2s, border-color .2s, background .2s;

    svg { width: 14px; height: 14px; }

    &:hover {
      color: var(--text);
      border-color: var(--border-strong);
      background: var(--surface);
    }

    &--accent {
      border-color: rgba(95, 20, 245, .3);
      color: var(--accent);

      &:hover {
        background: var(--accent-dim);
        border-color: var(--accent-muted);
        color: var(--accent);
      }
    }
  }

  .project-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
  }

  .project-desc {
    font-size: .83rem;
    line-height: 1.65;
    color: var(--muted);
    flex: 1;
  }

  .project-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .tag-icon {
    width: 13px;
    height: 13px;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
