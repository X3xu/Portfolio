---
import { PERSONAL } from '../data/resume'

const links = [
  { label: 'Email', value: PERSONAL.email, href: `mailto:${PERSONAL.email}`, external: false },
  { label: 'LinkedIn', value: 'linkedin.com/in/jesus-jimenez-dillana', href: PERSONAL.linkedin, external: true },
  { label: 'GitHub', value: 'github.com/X3xu', href: PERSONAL.github, external: true },
]
---

<section id="contact" aria-labelledby="contact-heading" class="section">
  <div class="container contact-inner">
    <div class="contact-left">
      <p class="section-label" aria-hidden="true">// Contacto</p>
      <h2 id="contact-heading" class="section-title">
        ¿Trabajamos<br />juntos?
      </h2>
      <p class="contact-copy">
        Disponible para roles remotos · Front&#8209;End / FullStack · +44.000&nbsp;€/año.
      </p>
    </div>

    <ul class="contact-links" role="list">
      {
        links.map(({ label, value, href, external }) => (
          <li>
            <a
              href={href}
              class="contact-entry"
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              aria-label={`${label}: ${value}${external ? ' (abre en nueva pestaña)' : ''}`}
            >
              <span class="entry-label">{label}</span>
              <span class="entry-value">{value}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section {
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .container {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-copy {
    font-size: 0.9375rem;
    color: var(--ink-2);
    line-height: 1.6;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
  }

  .contact-entry {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .contact-entry:hover {
    border-color: var(--accent);
  }

  .entry-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .entry-value {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
  }

  @media (max-width: 700px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
