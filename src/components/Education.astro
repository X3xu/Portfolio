---
import EducationItem from "./EducationItem.astro";

const EDUCATION = [
  {
    date: "2024",
    title: "Especialización en Ciberseguridad Avanzada en Entornos OT",
    company: "Mainjobs",
  },
  {
    date: "2019 — 2021",
    title: "Técnico Superior en Desarrollo de Aplicaciones Multiplataforma (DAM)",
    company: "IES Santísima Trinidad",
  },
  {
    date: "2017 — 2019",
    title: "Técnico en Sistemas Microinformáticos y Redes (SMR)",
    company: "IES Augustóbriga",
  },
];
---

<section id="education" class="sr">
  <p class="section-label">// formación</p>
  <h2 class="section-title">Educación</h2>

  <ol class="edu-list">
    {EDUCATION.map(item => (
      <EducationItem {...item} />
    ))}
  </ol>
</section>

<style lang="scss">
  .edu-list {
    margin-top: 44px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
</style>
