---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <hr class="divider" />
  <div class="footer-inner">
    <p class="footer-copy">
      <span class="footer-mono">© {year}</span>
      Jesús Jiménez Dillana — Hecho con
      <svg width="13" height="13" viewBox="0 0 24 24" fill="var(--accent)" stroke="none" aria-hidden="true">
        <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
      </svg>
      y Astro
    </p>
    <nav class="footer-nav">
      <a href="https://github.com/X3xu" target="_blank" rel="noopener">GitHub</a>
      <a href="https://www.linkedin.com/in/jes%C3%BAs-jim%C3%A9nez-dillana-a0bb60159/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:jesusjimenezfp@gmail.com">Email</a>
    </nav>
  </div>
</footer>

<style lang="scss">
  .site-footer {
    padding: 40px 0 32px;
    margin-top: 40px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: .8rem;
    color: var(--muted);
    svg { color: #e11d48; }
  }

  .footer-mono {
    font-family: var(--font-mono);
    font-size: .75rem;
  }

  .footer-nav {
    display: flex;
    gap: 20px;

    a {
      font-size: .8rem;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
      &:hover { color: var(--text); }
    }
  }
</style>
