---
---

<!-- ── NAV ── -->
<header id="site-nav">
  <nav>
    <a href="#contact" class="nav-logo">JJD</a>
    <ul>
      <li><a href="#contact">Sobre mí</a></li>
      <li><a href="#experiencie">Experiencia</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#projects">Proyectos</a></li>
      <li><a href="#education">Educación</a></li>
      <li><a href="#carta">Carta</a></li>
    </ul>
    <button id="theme-toggle" aria-label="Cambiar tema" data-hover>
      <!-- sun icon (shown in dark mode) -->
      <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <!-- moon icon (shown in light mode) -->
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>

<!-- ── HERO ── -->
<section class="hero" aria-label="Presentación">
  <div class="hero-inner">
    <p class="hero-code">// front-end specialist & fullstack developer</p>

    <h1 class="hero-name">
      Jesús<br />
      <span class="hero-name-accent">Jiménez</span>
    </h1>

    <p class="hero-role">
      +5 años creando arquitecturas web modernas, sistemas de diseño escalables
      y experiencias de usuario de alto rendimiento. Experto en React, Next.js,
      Core Web Vitals y AI-Driven Development.
    </p>

    <div class="hero-meta">
      <span class="hero-badge">
        <span class="badge-dot"></span>
        Disponible para proyectos
      </span>
      <span class="hero-sep">·</span>
      <span class="hero-location">📍 Madrid, España</span>
    </div>

    <div class="hero-cta">
      <a href="#projects" class="btn btn-accent">Ver proyectos</a>
      <a href="#contact" class="btn">Contactar</a>
    </div>
  </div>

  <!-- decorative number -->
  <span class="hero-num" aria-hidden="true">01</span>
</section>

<style lang="scss">
  /* ── NAV ── */
  #site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0;
    transition: background .3s, border-color .3s, box-shadow .3s;

    &.scrolled {
      background: var(--nav-scroll-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 1px 0 rgba(0,0,0,.05);
    }
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: .9rem;
    font-weight: 700;
    color: var(--accent) !important;
    letter-spacing: .1em;
    text-decoration: none;
    transition: opacity .2s;
    &:hover { opacity: .7; }
  }

  ul {
    display: flex;
    gap: 4px;
    list-style: none;
  }

  ul a {
    font-size: .82rem;
    font-weight: 500;
    color: var(--muted);
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    letter-spacing: .02em;
    transition: color .2s, background .2s;
    text-decoration: none;

    &:hover {
      color: var(--text);
      background: rgba(255,255,255,.07);
    }
  }

  [data-theme="light"] ul a:hover {
    background: rgba(0,0,0,.05);
  }

  /* ── Theme toggle ── */
  #theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    flex-shrink: 0;
    transition: color .2s, background .2s, border-color .2s;

    &:hover {
      color: var(--text);
      background: var(--surface-2);
      border-color: var(--border-strong);
    }
  }

  /* show sun in dark, moon in light */
  [data-theme="dark"]  .icon-moon { display: none; }
  [data-theme="dark"]  .icon-sun  { display: block; }
  [data-theme="light"] .icon-sun  { display: none; }
  [data-theme="light"] .icon-moon { display: block; }

  @media (max-width: 640px) {
    ul { display: none; }
    nav { padding: 0 16px; }
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 600px;
  }

  .hero-code {
    font-family: var(--font-mono);
    font-size: .78rem;
    color: var(--accent);
    letter-spacing: .08em;
    opacity: .85;
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -.04em;
    color: var(--text);
    animation: fadeUp .8s var(--ease-out) both;
  }

  .hero-name-accent {
    color: transparent;
    background: linear-gradient(135deg, #5F14F5 0%, #a78bfa 55%, #c084fc 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-role {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 420px;
    animation: fadeUp .8s .1s var(--ease-out) both;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: .82rem;
    color: var(--muted);
    animation: fadeUp .8s .2s var(--ease-out) both;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: .75rem;
    font-weight: 500;
    padding: 5px 12px;
    border-radius: 100px;
    border: 1px solid rgba(52,211,153,.25);
    background: rgba(52,211,153,.08);
    color: var(--green);
    letter-spacing: .03em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 2px rgba(52,211,153,.3);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: .3; }
  }

  .hero-sep { opacity: .3; }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    animation: fadeUp .8s .3s var(--ease-out) both;
  }

  /* ── decorative number ── */
  .hero-num {
    position: absolute;
    right: -10px;
    top: 60px;
    font-size: clamp(6rem, 16vw, 11rem);
    font-weight: 900;
    letter-spacing: -.06em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0,0,0,.05);
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: none; }
  }

  @media (max-width: 640px) {
    .hero { padding: 72px 0 60px; }
    .hero-num { display: none; }
  }
</style>

<script>
  /* ── Sticky nav ── */
  const nav = document.getElementById('site-nav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', scrollY > 40);
  }, { passive: true });

  /* ── Theme toggle ── */
  const btn = document.getElementById('theme-toggle')!;
  btn.addEventListener('click', () => {
    const html = document.documentElement;
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
